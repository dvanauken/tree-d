{
  "sets": {
    "__default__": {
      "name": "__default__",
      "description": "",
      "parentName": "",
      "baseDir": ".",
      "selection": {
        "includedRoots": [],
        "includedFiles": [],
        "excluded": [],
        "detail": {},
        "format": {
          "comments": {},
          "whitespace": {},
          "imports": {}
        }
      },
      "profile": {
        "commentPolicy": "KEEP_ALL",
        "whitespacePolicy": "TRIM_TRAILING",
        "importPolicy": "KEEP",
        "outputFormat": "INLINE_TREE",
        "autoReplacementSuggest": false,
        "tokenBudget": 120000,
        "commentDenylist": [
          "(?i)@author\\b",
          "(?i)\\b(created|modified|last changed|last edited)\\s+by\\b",
          "(?i)\\b(auto[- ]?generated|generated by|do not edit|do not modify)\\b",
          "(?i)\\b(copyright|all rights reserved|proprietary|confidential)\\b",
          "(?i)\\b(masterpiece|legendary|crafted by|behold|works on my machine)\\b",
          "(?i)\\b(todo|fixme|xxx|hack)\\s*[:(]",
          "(?i)\\b(change log|revision history|modification history)\\b"
        ],
        "sanitizers": []
      }
    }
  },
  "globalReplacements": [
    {
      "find": "Acme Financial Services LLC",
      "replacement": "ORG1",
      "regex": false,
      "assertGone": true
    },
    {
      "find": "Customer Portal",
      "replacement": "APP1",
      "regex": false,
      "assertGone": true
    },
    {
      "find": "(?i)\\b[A-Z0-9._%+-]+@acme\\.com\\b",
      "replacement": "user@example.com",
      "regex": true,
      "assertGone": true
    },
    {
      "find": "(?i)\\b(?:[a-z0-9-]+\\.)+corp\\.acme\\.com\\b",
      "replacement": "host.internal",
      "regex": true,
      "assertGone": true
    },
    {
      "find": "(?i)\\b(password|passwd|pwd)\\s*=\\s*\"[^\"]*\"",
      "replacement": "password=<redacted>",
      "regex": true,
      "assertGone": true
    },
    {
      "find": "(?i)\\bjdbc:[a-z0-9]+://[^\"\\s]+",
      "replacement": "jdbc:db://<redacted>",
      "regex": true,
      "assertGone": true
    },
    {
      "find": "\\bAKIA[0-9A-Z]{16}\\b",
      "replacement": "<aws-key-redacted>",
      "regex": true,
      "assertGone": true
    },
    {
      "find": "\\b10\\.\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}\\b",
      "replacement": "10.x.x.x",
      "regex": true,
      "assertGone": false
    }
  ]
}
